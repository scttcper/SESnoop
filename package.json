{
  "name": "sesnoop",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/scttcper/sesnoop"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "pnpm run build && vite preview",
    "deploy": "pnpm run build && pnpm run db:migrations:apply && wrangler deploy",
    "typecheck": "tsgo --build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:seed": "wrangler d1 execute sesnoop --local --file worker/db/seed.sql",
    "db:migrations:generate": "drizzle-kit generate",
    "db:migrations:apply": "wrangler d1 migrations apply DB --remote",
    "test": "vitest",
    "lint": "oxlint . && oxfmt --check",
    "lint:fix": "oxlint . --fix && oxfmt"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/zod-openapi": "^1.4.0",
    "@libsql/client": "^0.17.4",
    "@scalar/hono-api-reference": "^0.11.4",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/zod-adapter": "^1.167.0",
    "@tsndr/cloudflare-worker-jwt": "^3.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "echarts": "6.1.0",
    "echarts-for-react": "3.0.6",
    "hono": "^4.12.26",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "stoker": "^2.0.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.1",
    "@cloudflare/vitest-pool-workers": "^0.16.18",
    "@cloudflare/workers-types": "^4.20260621.1",
    "@ctrl/oxlint-config": "^1.5.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260622.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "packageManager": "pnpm@11.8.0"
}
